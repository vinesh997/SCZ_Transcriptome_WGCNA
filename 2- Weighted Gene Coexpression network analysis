# Load Required Libraries
###############################

library(BiocManager)
library(WGCNA)
library(tidyr)
library(DESeq2)
library(dplyr)
library(tibble)
library(limma)
library(ggplot2)
library(ggfortify)

###############################
# Set Working Directory
###############################

setwd("")

###############################
# Read Count Matrix
###############################

Data <- read.delim(
  "",
  check.names = FALSE,
  sep = ""
)

###############################
# Gene Filtering
# Retain genes expressed above
# threshold in minimum samples
###############################

smallestGroupSize <- 22

keep <- rowSums(Data >= 20) >= smallestGroupSize

data_filt <- Data[keep, ]

###############################
# Filter Only SCZ Samples
###############################

data_filt <- t(data_filt)
data_filt <- as.data.frame(data_filt)

data_filt <- rownames_to_column(
  data_filt,
  var = "Sample"
)

###############################
# Read Phenotype Data
###############################

Pheno <- read.csv("")

Pheno_SCZ <- Pheno[Pheno$Diagnosis == "SCZ", ]

# Optional filtering by centre
# Pheno_SCZ <- Pheno_SCZ[Pheno_SCZ$Centre == "SIU", ]

###############################
# Match Expression Data
# With SCZ Samples
###############################

dat_sub <- data_filt[
  data_filt$Sample %in% Pheno_SCZ$Sample.ID,
]

dat_sub <- dat_sub %>%
  remove_rownames() %>%
  column_to_rownames(var = "Sample")

dat_sub <- t(dat_sub)

###############################
# Create DESeq2 Dataset
###############################

dds <- DESeqDataSetFromMatrix(
  dat_sub,
  Pheno_SCZ,
  design = ~ 1
)

###############################
# Extract Count Matrix
###############################

count_matrix <- counts(dds)

###############################
# Variance Stabilizing
# Transformation (VST)
###############################

vsd <- varianceStabilizingTransformation(dds)

mat <- assay(vsd)

# Alternative batch correction methods
# mod <- model.matrix(~1, data = Pheno)
# batch <- factor(Pheno$Batch, levels = c("A", "B"))
# combat.df <- ComBat_seq(mat, batch = Pheno$Batch)

###############################
# Convert Batch Variable
# To Factor
###############################

Pheno_SCZ$Batch <- as.factor(Pheno_SCZ$Batch)

###############################
# Create Covariate Model Matrix
###############################

design.Covariates <- model.matrix(
  ~ Age + Sex + T_cells_CD4_memory_activated,
  data = Pheno_SCZ
)

###############################
# Batch Effect Removal
# Using limma
###############################

mat.adjusted <- limma::removeBatchEffect(
  mat,
  batch = Pheno_SCZ$Batch,
  covariates = design.Covariates[, -1]
)

# Optional sample removal
# mat.adjusted <- mat.adjusted[, -8]

###############################
# PCA Visualization
# Before and After
# Batch Correction
###############################

autoplot(
  prcomp(t(mat), scale. = TRUE),
  data = Pheno_SCZ,
  colour = "Batch"
) +
  ggtitle("Before Batch Correction")

autoplot(
  prcomp(t(mat.adjusted), scale. = TRUE),
  data = Pheno_SCZ,
  colour = "Batch"
) +
  ggtitle("After Batch Correction")

###############################
# Transpose Matrix for WGCNA
# Rows = Samples
# Columns = Genes
###############################

mat_adjusted_t <- t(mat.adjusted)

############################################################
# WGCNA ANALYSIS
############################################################

# Tutorials Referenced:
# https://rpubs.com/natmurad/WGCNA
# https://github.com/kpatel427/YouTubeTutorials/blob/main/WGCNA.R
# https://github.com/Lindseynicer/WGCNA_tutorial/blob/main/WGCNA_tutorial_Rscript

###############################
# Check for Missing Values
###############################

gsg <- goodSamplesGenes(
  mat_adjusted_t,
  verbose = 3
)

gsg$allOK

###############################
# Sample Clustering
###############################

sampleTree <- hclust(
  dist(mat_adjusted_t),
  method = "average"
)

sizeGrWindow(12, 9)

par(cex = 0.6)
par(mar = c(0, 4, 2, 0))

plot(
  sampleTree,
  main = "Sample clustering to detect outliers",
  sub = "",
  xlab = "",
  cex.lab = 1.5,
  cex.axis = 1.5,
  cex.main = 2
)

###############################
# Prepare Trait Data
###############################

# Optional external trait file
# PS <- read.csv("PANSS_Profile_TScore.csv", check.names = FALSE)

PS <- Pheno_SCZ %>%
  remove_rownames() %>%
  column_to_rownames(var = "Sample.ID")

PS <- PS[, -c(1:2, 7:11, 15:20, 22:39)]

traitData <- as.data.frame(PS)

symptom_names <- colnames(traitData)

###############################
# Convert Traits to Numeric
###############################

PS <- mutate_all(PS, as.numeric)

colnames(PS) <- symptom_names

PS <- as.data.frame(PS)

# Optional sample removal
# PS <- PS[-8, ]

###############################
# Match Trait Data
# With Expression Samples
###############################

Samples <- rownames(mat_adjusted_t)

traitData <- rownames_to_column(
  traitData,
  var = "Samples"
)

traitRows <- match(
  Samples,
  traitData$Samples
)

datTraits <- traitData[traitRows, -1]

datTraits[] <- lapply(
  datTraits,
  function(x) as.numeric(as.character(x))
)

rownames(datTraits) <- traitData[traitRows, 1]

###############################
# Garbage Collection
###############################

collectGarbage()

Pheno_SCZ$Batch <- as.factor(Pheno_SCZ$Batch)

###############################
# Re-cluster Samples
# With Trait Heatmap
###############################

sampleTree3 <- hclust(
  dist(mat_adjusted_t),
  method = "average"
)

###############################
# Convert Traits to Colors
###############################

traitColors <- numbers2colors(
  datTraits,
  signed = TRUE
)

###############################
# Plot Dendrogram
# And Trait Heatmap
###############################

plotDendroAndColors(
  sampleTree3,
  traitColors,
  groupLabels = colnames(datTraits),
  main = "Sample dendrogram and trait heatmap"
)

###############################
# Soft Threshold Selection
###############################

power <- c(
  c(1:10),
  seq(from = 12, to = 30, by = 2)
)

###############################
# Network Topology Analysis
###############################

sft <- pickSoftThreshold(
  mat_adjusted_t,
  powerVector = power,
  networkType = "unsigned",
  verbose = 5
)

###############################
# Plot Scale-Free Topology
###############################

sizeGrWindow(12, 9)

par(mfrow = c(1, 2))

cex1 = 0.9

plot(
  sft$fitIndices[, 1],
  -sign(sft$fitIndices[, 3]) * sft$fitIndices[, 2],
  xlab = "Soft Threshold (power)",
  ylab = "Scale Free Topology Model Fit, signed R^2",
  type = "n",
  main = "Scale independence"
)

text(
  sft$fitIndices[, 1],
  -sign(sft$fitIndices[, 3]) * sft$fitIndices[, 2],
  labels = power,
  cex = cex1,
  col = "red"
)

# R^2 cut-off reference line
abline(h = 0.8, col = "red")

###############################
# Plot Mean Connectivity
###############################

plot(
  sft$fitIndices[, 1],
  sft$fitIndices[, 5],
  xlab = "Soft Threshold (power)",
  ylab = "Mean Connectivity",
  type = "n",
  main = "Mean connectivity"
)

text(
  sft$fitIndices[, 1],
  sft$fitIndices[, 5],
  labels = power,
  cex = cex1,
  col = "red"
)

# Optional connectivity threshold
# abline(h = 100, col = "red")

############################################################
# MODULE CONSTRUCTION
# AND TRAIT RELATIONSHIPS
############################################################

# Constructing unsigned co-expression network

cor <- WGCNA::cor

# Power selected according to
# WGCNA recommendations

net <- blockwiseModules(
  mat_adjusted_t,
  power = 9,
  maxBlockSize = 16000,
  deepSplit = 0,
  networkType = "unsigned",
  minModuleSize = 30,
  reassignThreshold = 0,
  mergeCutHeight = 0.25,
  numericLabels = FALSE,
  saveTOMs = FALSE,
  verbose = 5
)

