#==============================#
# Loading required libraries
#==============================#
library(BiocManager)
library(WGCNA)
library(tidyr)
library(DESeq2)
library(dplyr)
library(tibble)
library(limma)
library(ggplot2)
library(ggfortify)

#==============================#
# Set working directory
#==============================#
setwd(" ")

#==============================#
# Read raw count matrix
# Rows = genes, Columns = samples
#==============================#
Data<- read.delim(" ", check.names = F, sep = "")

#==============================#
# Filter lowly expressed genes
# Keep genes with counts >=20 in at least
# 'smallestGroupSize' number of samples
#==============================#
smallestGroupSize <- 22
keep <- rowSums(Data >= 20) >= smallestGroupSize
data_filt<- Data[keep,]

#==============================#
# Prepare count matrix and retain
# only schizophrenia (SCZ) samples
#==============================#
data_filt<- t(data_filt)
data_filt<- as.data.frame(data_filt)
data_filt<- rownames_to_column(data_filt, var = "Sample")

# Read phenotype information
Pheno<- read.csv(" ")

# Subset phenotype data for SCZ samples only
Pheno_SCZ<- Pheno[Pheno$Diagnosis == "SCZ",]

# Optional centre-specific filtering
#Pheno_SCZ<- Pheno_SCZ[Pheno_SCZ$Centre == "SIU",]

# Match count matrix samples with phenotype samples
dat_sub<- data_filt[data_filt$Sample %in% Pheno_SCZ$Sample.ID,]
dat_sub<- dat_sub %>% remove_rownames() %>% column_to_rownames(var = "Sample")
dat_sub<-t(dat_sub)

#==============================#
# Create DESeq2 dataset object
# No differential expression design
# used here (design = ~1)
#==============================#
dds <- DESeqDataSetFromMatrix(dat_sub,
                              Pheno_SCZ,
                              design = ~ 1)

# Extract raw counts from DESeq object
count_matrix <- counts(dds)

#==============================#
# Variance Stabilizing Transformation
# Improves homoscedasticity for
# downstream network analysis
#==============================#
vsd<- varianceStabilizingTransformation(dds)
mat<- assay(vsd)

# Convert batch variable to factor
Pheno_SCZ$Batch<- as.factor(Pheno_SCZ$Batch)

#==============================#
# Build design matrix containing
# biological covariates to preserve
# during batch correction
#==============================#
design.Covariates <- model.matrix(~ Age + Sex + T_cells_CD4_memory_activated, data=Pheno_SCZ)

#==============================#
# Remove batch effects while retaining
# variation explained by selected
# biological covariates
#==============================#
mat.adjusted <- limma::removeBatchEffect(mat,
                                         batch = Pheno_SCZ$Batch,
                                         covariates = design.Covariates[,-1])

# Optional sample removal
#mat.adjusted<- mat.adjusted[,-8]

#==============================#
# PCA visualization before and after
# batch correction
#==============================#
autoplot(prcomp(t(mat), scale. = T),
         data = Pheno_SCZ,
         colour="Batch") +
  ggtitle("Before Batch Correction")

autoplot(prcomp(t(mat.adjusted), scale. = T),
         data = Pheno_SCZ,
         colour= "Batch") +
  ggtitle("After Batch Correction")

#==============================#
# Transpose expression matrix
# WGCNA requires:
# Rows = samples
# Columns = genes
#==============================#
mat_adjusted_t<- t(mat.adjusted)


######################WGCNA analysis #########################################
#==============================#
# Check for genes/samples with
# excessive missing values
#==============================#
gsg <- goodSamplesGenes(mat_adjusted_t, verbose = 3);
gsg$allOK

#==============================#
# Hierarchical clustering of samples
# for outlier detection
#==============================#
sampleTree <- hclust(dist(mat_adjusted_t), method = "average");

sizeGrWindow(12,9)
par(cex = 0.6);
par(mar = c(0,4,2,0))

plot(sampleTree,
     main = "Sample clustering to detect outliers",
     sub="",
     xlab="",
     cex.lab = 1.5,
     cex.axis = 1.5,
     cex.main = 2)

#==============================#
# Prepare phenotype traits for
# module-trait association analysis
#==============================#

PS<- Pheno_SCZ %>% remove_rownames() %>% column_to_rownames(var = "Sample.ID")

# Select only variables of interest
PS<- PS[,-c(1:6, 10:15,17)]

traitData <-as.data.frame(PS)

# Preserve original trait names
symptom_names <- colnames(traitData)

# Convert all trait variables to numeric
PS<- mutate_all(PS, as.numeric)

# Restore trait names
colnames(PS) <- symptom_names
PS<- as.data.frame(PS)

# Optional sample removal
#PS<- PS[-8,]

#==============================#
# Match trait data order with
# expression matrix sample order
#==============================#
Samples <- rownames(mat_adjusted_t)

traitData<- rownames_to_column(traitData, var = "Samples")

traitRows<- match(Samples, traitData$Samples)

datTraits<- traitData[traitRows, -1]

datTraits[] <- lapply(datTraits,
                      function(x) as.numeric(as.character(x)))

rownames(datTraits) = traitData[traitRows, 1]

collectGarbage()

Pheno_SCZ$Batch<- as.factor(Pheno_SCZ$Batch)

#==============================#
# Re-cluster samples and visualize
# trait distribution across samples
#==============================#
sampleTree3<- hclust(dist(mat_adjusted_t), method = "average")

# Convert trait values to color scale
traitColors<- numbers2colors(datTraits, signed = TRUE)

# Plot sample dendrogram with trait heatmap
plotDendroAndColors(sampleTree3,
                    traitColors,
                    groupLabels = colnames(datTraits),
                    main = "Sample dendrogram and trait heatmap")

#==============================#
# Soft-threshold power selection
#==============================#

# Candidate powers to evaluate
power <- c(c(1:10), seq(from = 12, to = 30, by = 2))

# Evaluate scale-free topology fit
sft <- pickSoftThreshold(mat_adjusted_t,
                         powerVector = power,
                         networkType = "unsigned",
                         verbose = 5)

#==============================#
# Plot scale-free topology fit
# and mean connectivity
#==============================#
sizeGrWindow(12,9)

par(mfrow = c(1,2))
cex1 = 0.9

plot(sft$fitIndices[,1],
     -sign(sft$fitIndices[,3])*sft$fitIndices[,2],
     xlab="Soft Threshold (power)",
     ylab="Scale Free Topology Model Fit,signed R^2",
     type="n",
     main = paste("Scale independence"))

text(sft$fitIndices[,1],
     -sign(sft$fitIndices[,3])*sft$fitIndices[,2],
     labels=power,
     cex=cex1,
     col="red")

# Recommended scale-free topology cutoff
abline(h = 0.8, col="red")

plot(sft$fitIndices[,1],
     sft$fitIndices[,5],
     xlab="Soft Threshold (power)",
     ylab="Mean Connectivity",
     type="n",
     main = paste("Mean connectivity"))

text(sft$fitIndices[,1],
     sft$fitIndices[,5],
     labels=power,
     cex=cex1,
     col="red")

#abline(h = 100, col="red")


############# MODULE CONSTRUCTION & TRAIT RELATIONSHIPS ###############

#==============================#
# Construct unsigned co-expression
# network and identify modules
#==============================#

cor <- WGCNA::cor

# Power selected from scale-free analysis
net<- blockwiseModules(mat_adjusted_t,
                       power = 9,
                       maxBlockSize = 16000,
                       deepSplit = 0,
                       networkType = "unsigned",
                       minModuleSize = 30,
                       reassignThreshold = 0,
                       mergeCutHeight = 0.25,
                       numericLabels = FALSE,
                       saveTOMs = FALSE,
                       verbose = 5)

#==============================#
# Visualize module assignment
#==============================#

# Number of genes in each module
table(net$colors)

sizeGrWindow(12, 9)

mergedColors<- labels2colors(net$colors)

plotDendroAndColors(net$dendrograms[[1]],
                    net$colors,
                    "Module colors",
                    dendroLabels = FALSE,
                    hang = 0.03,
                    addGuide = TRUE,
                    guideHang = 0.05)

# Compare modules before and after merging
plotDendroAndColors(net$dendrograms[[1]],
                    cbind(net$unmergedColors, net$colors),
                    c("unmerged", "merged"),
                    dendroLabels = FALSE,
                    addGuide = TRUE,
                    hang= 0.03,
                    guideHang = 0.05)

#==============================#
# Module-trait relationship analysis
#==============================#

moduleColors<- net$colors
MEs<- net$MEs

# Number of genes and samples
nGenes<- ncol(mat_adjusted_t)
nSamples<- nrow(mat_adjusted_t)

# Calculate module eigengenes
MEs0<- moduleEigengenes(mat_adjusted_t, moduleColors)$eigengenes
MEs<- orderMEs(MEs0)

# Correlate module eigengenes with traits
moduleTraitCor<- cor(MEs, PS, use = "all.obs", method = "p")
moduleTraitPvalue<- corPvalueStudent(moduleTraitCor, nSamples)

# Create matrix containing correlations and p-values
textMatrix<- paste(signif(moduleTraitCor, 2),
                   "\n(",
                   signif(moduleTraitPvalue, 1),
                   ")",
                   sep = "")

dim(textMatrix) = dim(moduleTraitCor)

#==============================#
# Heatmap of module-trait
# correlations
#==============================#
sizeGrWindow(10,6)

par(mar = c(10, 9, 1, 1))

labeledHeatmap(Matrix = moduleTraitCor,
               xLabels = names(PS),
               yLabels = names(MEs),
               ySymbols = names(MEs),
               colorLabels = FALSE,
               colors = blueWhiteRed(50),
               textMatrix = textMatrix,
               setStdMargins = FALSE,
               cex.text = 0.5,
               zlim = c(-1,1),
               main = paste("Module-trait relationships"))

#dev.off()

#==============================#
# Select trait of interest
# for downstream hub gene analysis
#==============================#
Trait<- as.data.frame(PS$Activation)
names(Trait)<- "Trait"

# Module names without "ME" prefix
modNames<- substring(names(MEs), 3)

#==============================#
# Calculate module membership (MM)
# for each gene
#==============================#
geneModuleMembership<- as.data.frame(
  cor(mat_adjusted_t,
      MEs,
      use = "all.obs",
      method = "spearman"))

MMPvalue<- as.data.frame(
  corPvalueStudent(as.matrix(geneModuleMembership),
                   nSamples))

names(geneModuleMembership)<- paste("MM", modNames, sep="")
names(MMPvalue)<- paste("p.MM", modNames, sep="")

#==============================#
# Calculate gene significance (GS)
# for selected trait
#==============================#
geneTraitSignificance<- as.data.frame(
  cor(mat_adjusted_t,
      Trait,
      use = "all.obs",
      method = "spearman"))

GSPvalue<- as.data.frame(
  corPvalueStudent(as.matrix(geneTraitSignificance),
                   nSamples))

names(geneTraitSignificance)<- paste("GS.", names(Trait), sep="")
names(GSPvalue)<- paste("p.GS.", names(Trait), sep="")

#==============================#
# Scatter plot of MM vs GS for
# a selected module
#==============================#
module<- "royalblue"

column<- match(module, modNames)

moduleGenes<- moduleColors == module

par(mfrow = c(1,1));

verboseScatterplot(abs(geneModuleMembership[moduleGenes, column]),
                   abs(geneTraitSignificance[moduleGenes, 1]),
                   xlab = paste("Module Membership in", module, "module"),
                   ylab = "Gene significance for Guilt Feelings",
                   main = paste("Module membership vs. gene significance\n"),
                   cex.main = 1.2,
                   cex.lab = 1.2,
                   cex.axis = 1.2,
                   col = module,
                   abline = TRUE)

# MM and GS cutoffs for hub-gene selection
abline(v = 0.8, col = "red", lty = 2)
abline(h = 0.2, col = "blue", lty = 2)

#==============================#
# Compile gene information table
# containing GS and MM values
#==============================#
geneInfo0<- data.frame(EST = colnames(mat_adjusted_t),
                       moduleColor = moduleColors,
                       geneTraitSignificance,
                       GSPvalue)

modOrder<- order(-abs(cor(MEs, Trait, use = "p")))

modOrder<- modOrder[modOrder > 0 &
                      modOrder <= ncol(geneModuleMembership)]

for (mod in 1:ncol(geneModuleMembership)) {
  oldNames = names(geneInfo0)
  
  geneInfo0 = data.frame(geneInfo0,
                         geneModuleMembership[, modOrder[mod]],
                         MMPvalue[, modOrder[mod]])
  
  names(geneInfo0) = c(oldNames,
                       paste("MM.", modNames[modOrder[mod]], sep=""),
                       paste("p.MM.", modNames[modOrder[mod]], sep=""))
}

geneOrder<- order(geneInfo0$moduleColor,
                  -abs(geneInfo0$GS.Trait))

geneInfo<- geneInfo0[geneOrder,]

#write.csv(geneInfo, file = " ")

#==============================#
# Extract genes belonging to a
# specific module
#==============================#
ModuleGenes<- geneInfo[geneInfo$moduleColor == "cyan", ]

#write.csv(ModuleGenes, " ")

#==============================#
# Identify candidate hub genes
# using GS and MM thresholds
#==============================#
filtered_data<- ModuleGenes[
  ModuleGenes$GS.Trait > 0.2 &
    ModuleGenes$MM.cyan > 0.8,
]

# View candidate hub genes
print(filtered_data)

# Save filtered hub genes
#write.csv(filtered_data, " ", row.names = FALSE)
