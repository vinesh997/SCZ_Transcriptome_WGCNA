#loading the libraries
library(BiocManager)
library(WGCNA)
library(tidyr)
library(DESeq2)
library(dplyr)
library(tibble)
library(limma)
library(ggplot2)
library(ggfortify)

#setting the workimg directory
setwd(" ")

#Reading the count matrix
Data<- read.delim(" ", check.names = F, sep = "")

#filtering the genes 
#Retaining genes expressed above threshold in minimum number of samples
smallestGroupSize <- 22
keep <- rowSums(Data >= 20) >= smallestGroupSize
data_filt<- Data[keep,]

#filtering only SCZ samples
#Transpose count matrix for sample-wise filtering
data_filt<- t(data_filt)
data_filt<- as.data.frame(data_filt)
data_filt<- rownames_to_column(data_filt, var = "Sample")

#Reading phenodata
Pheno<- read.csv("Phenodata_16_12_25.csv")

#Retaining only SCZ samples from phenodata
Pheno_SCZ<- Pheno[Pheno$Diagnosis == "SCZ",]

#Filtering expression data for SCZ samples
dat_sub<- data_filt[data_filt$Sample %in% Pheno_SCZ$Sample.ID,]

#Restoring gene × sample format
dat_sub<- dat_sub %>% remove_rownames() %>% column_to_rownames(var = "Sample")
dat_sub<-t(dat_sub)

#creating a DESeqDataSet object
dds <- DESeqDataSetFromMatrix(dat_sub,
                              Pheno_SCZ,
                              design = ~ 1)

#countmatrix from DESeqDataSet
count_matrix <- counts(dds)

#transforming the data using vst
#Variance stabilizing transformation for downstream analysis
vsd<- varianceStabilizingTransformation(dds)
mat<- assay(vsd)

#Converting batch column to factor
Pheno_SCZ$Batch<- as.factor(Pheno_SCZ$Batch)

#creating a model with all the covariates to be adjusted
design.Covariates <- model.matrix(~ Age + Sex + T.cells.CD4.memory.activated, data=Pheno_SCZ)

#adjusting covariates using limma 
#Removing batch effects while adjusting for age and sex
mat.adjusted <- limma::removeBatchEffect(mat, batch = Pheno_SCZ$Batch, covariates = design.Covariates[,-1])

#visualizing for batch correction on PCA
#PCA before batch correction
autoplot(prcomp(t(mat), scale. = T), data = Pheno_SCZ, colour="Batch") + ggtitle("Before Batch Correction")

#PCA after batch correction
autoplot(prcomp(t(mat.adjusted), scale. = T), data = Pheno_SCZ, colour= "Batch") + ggtitle("After Batch Correction")

#transposing the data for WGCNA 
#WGCNA requires samples as rows and genes as columns
mat_adjusted_t<- t(mat.adjusted)

######################WGCNA analysis #########################################   

#Checking of missing values.
gsg <- goodSamplesGenes(mat_adjusted_t, verbose = 3);
gsg$allOK

#cluster the samples
#Hierarchical clustering to identify potential outlier samples
sampleTree <- hclust(dist(mat_adjusted_t), method = "average");

#Plot sample clustering dendrogram
sizeGrWindow(12,9)
par(cex = 0.6);
par(mar = c(0,4,2,0))
plot(sampleTree, main = "Sample clustering to detect outliers", sub="", xlab="", cex.lab = 1.5, 
     cex.axis = 1.5, cex.main = 2)

#Preparing clinical trait data
PS<- Pheno_SCZ %>% remove_rownames() %>% column_to_rownames(var = "Sample.ID")

#Retaining only selected clinical variables
PS<- PS[,-c(1:2, 7:21)]

traitData <-as.data.frame(PS)

#Saving trait names
symptom_names <- colnames(traitData)

#Converting traits to numeric format
PS<- mutate_all(PS, as.numeric)
colnames(PS) <- symptom_names
PS<- as.data.frame(PS)

#checking the sequence of samples 
#Ensuring trait data and expression data are aligned
Samples <- rownames(mat_adjusted_t)
traitData<- rownames_to_column(traitData, var = "Samples")
traitRows<- match(Samples, traitData$Samples)
datTraits<- traitData[traitRows, -1]

#Converting all trait columns to numeric
datTraits[] <- lapply(datTraits, function(x) as.numeric(as.character(x)))

#Assigning sample names as rownames
rownames(datTraits) = traitData[traitRows, 1]

#Clearing unused memory
collectGarbage()

Pheno_SCZ$Batch<- as.factor(Pheno_SCZ$Batch)

####### Re-cluster samples with clinical traits

#Re-clustering samples after preprocessing
sampleTree3<- hclust(dist(mat_adjusted_t), method = "average")

# Convert traits to a color representation: white means low, red means high, grey means missing entry
traitColors<- numbers2colors(datTraits, signed = TRUE)

# Plot the sample dendrogram and the colors underneath.
plotDendroAndColors(sampleTree3, traitColors,
                    groupLabels = colnames(datTraits),
                    main = "Sample dendrogram and trait heatmap")

# Choose a set of soft-thresholding powers
power <- c(c(1:10), seq(from = 12, to = 30, by = 2))

# Call the network topology analysis function
#Evaluating scale-free topology fit across soft-thresholding powers
sft <- pickSoftThreshold(mat_adjusted_t,
                         powerVector = power,
                         networkType = "signed",
                         verbose = 5)

# Scale-free topology fit index as a function of the soft-thresholding power
sizeGrWindow(12,9)
par(mfrow = c(1,2))
cex1 = 0.9

#Plotting scale-free topology fit index
plot(sft$fitIndices[,1], -sign(sft$fitIndices[,3])*sft$fitIndices[,2],
     xlab="Soft Threshold (power)",ylab="Scale Free Topology Model Fit,signed R^2",type="n",
     main = paste("Scale independence"))

text(sft$fitIndices[,1], -sign(sft$fitIndices[,3])*sft$fitIndices[,2],
     labels=power,cex=cex1,col="red");

# this line corresponds to using an R^2 cut-off 
abline(h = 0.8, col="red") 

# Mean connectivity as a function of the soft-thresholding power
plot(sft$fitIndices[,1], sft$fitIndices[,5],
     xlab="Soft Threshold (power)",ylab="Mean Connectivity", type="n",
     main = paste("Mean connectivity")) 

text(sft$fitIndices[,1], sft$fitIndices[,5], labels=power, cex=cex1,col="red")

############# MODULE CONSTRUCTION & TRAIT RELATIONSHIPS ###############

# Constructing signed network in single block using sft power
cor <- WGCNA::cor

#selecting power as 18 according to WGCNA FAQ

#Constructing co-expression modules
net<- blockwiseModules(mat_adjusted_t, power = 9, maxBlockSize = 15000,  
                       deepSplit = 0, networkType = "unsigned", minModuleSize = 30,
                       reassignThreshold = 0, mergeCutHeight = 0.25, numericLabels = FALSE,
                       saveTOMs = FALSE, verbose = 5)

# get number of genes for each module and plot dendrogram
table(net$colors)

#Visualizing module clustering dendrogram
sizeGrWindow(12, 9)
mergedColors<- labels2colors(net$colors)

plotDendroAndColors(net$dendrograms[[1]], net$colors,
                    "Module colors",
                    dendroLabels = FALSE, hang = 0.03,
                    addGuide = TRUE, guideHang = 0.05)

# Plot the dendrogram and the module colors before and after merging underneath
plotDendroAndColors(net$dendrograms[[1]], cbind(net$unmergedColors, net$colors),
                    c("unmerged", "merged"),
                    dendroLabels = FALSE,
                    addGuide = TRUE,
                    hang= 0.03,
                    guideHang = 0.05)

## Relating modules with external traits

#Extracting module colors and eigengenes
moduleColors<- net$colors
MEs<- net$MEs

# Define number of genes and samples
nGenes<- ncol(mat_adjusted_t)
nSamples<- nrow(mat_adjusted_t)

# Recalculate MEs with color labels
MEs0<- moduleEigengenes(mat_adjusted_t, moduleColors)$eigengenes
MEs<- orderMEs(MEs0)

#Calculating module-trait correlations
moduleTraitCor<- cor(MEs, PS, use = "all.obs", method = "p")
moduleTraitPvalue<- corPvalueStudent(moduleTraitCor, nSamples)

# Will display correlations and their p-values
textMatrix<- paste(signif(moduleTraitCor, 2), "\n(",
                   signif(moduleTraitPvalue, 1), ")", sep = "");

dim(textMatrix) = dim(moduleTraitCor)

## Display the correlation values within a heatmap plot
sizeGrWindow(10,6)
par(mar = c(12, 9, 1, 1))

#Plotting module-trait relationship heatmap
labeledHeatmap(Matrix = moduleTraitCor,
               xLabels = names(PS),
               yLabels = names(MEs),
               ySymbols = names(MEs),
               colorLabels = FALSE,
               colors = blueWhiteRed(50),
               textMatrix = textMatrix,
               setStdMargins = FALSE,
               cex.text = 0.5,
               zlim = c(-1,1))

#dev.off()

#Defining the variable 
Trait<- as.data.frame(PS$N)
names(Trait)<- "Trait"

# names (colors) of the modules
modNames<- substring(names(MEs), 3)

# calculating module membership and p-value by using Pearson correlation between expression data and module eigengens
geneModuleMembership<- as.data.frame(cor(mat_adjusted_t, MEs, use = "all.obs", method = "spearman"))
MMPvalue<- as.data.frame(corPvalueStudent(as.matrix(geneModuleMembership), nSamples))

names(geneModuleMembership)<- paste("MM", modNames, sep="")
names(MMPvalue)<- paste("p.MM", modNames, sep="")

# calculating gene significance and p-value
geneTraitSignificance<- as.data.frame(cor(mat_adjusted_t, Trait, use = "all.obs", method = "spearman")) #pearson method
GSPvalue<- as.data.frame(corPvalueStudent(as.matrix(geneTraitSignificance), nSamples))

names(geneTraitSignificance)<- paste("GS.", names(Trait), sep="")
names(GSPvalue)<- paste("p.GS.", names(Trait), sep="")

module<- "lightyellow"   #########################putting the color below the plot

#Identifying module column index
column<- match(module, modNames)

#Selecting genes belonging to selected module
moduleGenes<- moduleColors == module

par(mfrow = c(1,1));

#Scatterplot of module membership vs gene significance
verboseScatterplot(abs(geneModuleMembership[moduleGenes, column]),
                   abs(geneTraitSignificance[moduleGenes, 1]),
                   xlab = paste("Module Membership in", module, "module"),
                   ylab = "Gene significance for Negative symptoms",
                   main = paste("Module membership vs. gene significance\n"),
                   cex.main = 1.2, cex.lab = 1.2, cex.axis = 1.2, 
                   col = "black", abline = F)

# Add vertical and horizontal cutoff lineshttp://127.0.0.1:14735/graphics/plot_zoom_png?width=477&height=330

#Vertical cutoff for module membership
abline(v = 0.8, col = "red", lty = 2)  # Vertical line at X = 0.6

#Horizontal cutoff for gene significance
abline(h = 0.2, col = "blue", lty = 2) # Horizontal line at Y = 0.2http://127.0.0.1:19625/graphics/plot_zoom_png?width=396&height=425

#Identifying most important genes for one determined characteristic inside of the cluster
geneInfo0<- data.frame(EST = colnames(mat_adjusted_t),
                       moduleColor = moduleColors,
                       geneTraitSignificance,
                       GSPvalue)

#Ordering modules based on correlation with trait
modOrder<- order(-abs(cor(MEs, Trait, use = "p")))
modOrder<- modOrder[modOrder > 0 & modOrder <= ncol(geneModuleMembership)]

#Appending module membership and p-values
for (mod in 1:ncol(geneModuleMembership)) {
  oldNames = names(geneInfo0)
  geneInfo0 = data.frame(geneInfo0, geneModuleMembership[, modOrder[mod]],
                         MMPvalue[, modOrder[mod]])
  names(geneInfo0) = c(oldNames, paste("MM.", modNames[modOrder[mod]], sep=""),
                       paste("p.MM.", modNames[modOrder[mod]], sep=""))
}

#Ordering genes by module color and gene significance
geneOrder<- order(geneInfo0$moduleColor, -abs(geneInfo0$GS.Trait))
geneInfo<- geneInfo0[geneOrder,]

#write.csv(geneInfo, file = " ")

# Subset genes belonging to a module
ModuleGenes<- geneInfo[geneInfo$moduleColor == "lightyellow", ]

#Saving all genes from selected module
#write.csv(ModuleGenes, " ", row.names = F)

# Filter the GS-MM file
#Filtering genes based on GS and MM thresholds
filtered_data<- ModuleGenes[ModuleGenes$GS.Trait > 0.2 & ModuleGenes$MM.lightyellow >  0.8, ]

# View the filtered data
print(filtered_data)

# Save the filtered data to a new file
#write.csv(filtered_data, " ", row.names = FALSE)
